<Window x:Class="ApaFlowRecorder.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="Workflow Spec Recorder"
        Icon="Assets/AppIcon.ico"
        Height="880"
        Width="1440"
        MinHeight="780"
        MinWidth="1180"
        FontFamily="Segoe UI, Microsoft YaHei UI, Microsoft YaHei, sans-serif"
        FontSize="13"
        Foreground="#1F2328"
        Background="#F6F7F9">
    <Window.Resources>
        <FontFamily x:Key="AppFontFamily">Segoe UI, Microsoft YaHei UI, Microsoft YaHei, sans-serif</FontFamily>

        <Color x:Key="ColorBackground">#F6F7F9</Color>
        <Color x:Key="ColorSurface">#FFFFFF</Color>
        <Color x:Key="ColorSurfaceMuted">#FAFAFB</Color>
        <Color x:Key="ColorTextPrimary">#1F2328</Color>
        <Color x:Key="ColorTextSecondary">#5D6673</Color>
        <Color x:Key="ColorTextTertiary">#8A94A3</Color>
        <Color x:Key="ColorBorder">#E1E5EA</Color>
        <Color x:Key="ColorBorderStrong">#CBD2DA</Color>
        <Color x:Key="ColorAccent">#2563EB</Color>
        <Color x:Key="ColorAccentHover">#1D4ED8</Color>
        <Color x:Key="ColorAccentSoft">#EAF1FF</Color>
        <Color x:Key="ColorNeutral">#6B7280</Color>
        <Color x:Key="ColorNeutralSoft">#F1F3F5</Color>
        <Color x:Key="ColorGreen">#16833A</Color>
        <Color x:Key="ColorGreenSoft">#EAF7EE</Color>
        <Color x:Key="ColorAmber">#B7791F</Color>
        <Color x:Key="ColorAmberSoft">#FFF6DE</Color>
        <Color x:Key="ColorRed">#C92A2A</Color>
        <Color x:Key="ColorRedSoft">#FFF0F0</Color>

        <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource ColorBackground}" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource ColorSurface}" />
        <SolidColorBrush x:Key="SurfaceMutedBrush" Color="{StaticResource ColorSurfaceMuted}" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource ColorTextPrimary}" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource ColorTextSecondary}" />
        <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource ColorTextTertiary}" />
        <SolidColorBrush x:Key="BorderBrushToken" Color="{StaticResource ColorBorder}" />
        <SolidColorBrush x:Key="BorderStrongBrush" Color="{StaticResource ColorBorderStrong}" />
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource ColorAccent}" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource ColorAccentHover}" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="{StaticResource ColorAccentSoft}" />
        <SolidColorBrush x:Key="NeutralBrush" Color="{StaticResource ColorNeutral}" />
        <SolidColorBrush x:Key="NeutralSoftBrush" Color="{StaticResource ColorNeutralSoft}" />
        <SolidColorBrush x:Key="GreenBrush" Color="{StaticResource ColorGreen}" />
        <SolidColorBrush x:Key="GreenSoftBrush" Color="{StaticResource ColorGreenSoft}" />
        <SolidColorBrush x:Key="AmberBrush" Color="{StaticResource ColorAmber}" />
        <SolidColorBrush x:Key="AmberSoftBrush" Color="{StaticResource ColorAmberSoft}" />
        <SolidColorBrush x:Key="RedBrush" Color="{StaticResource ColorRed}" />
        <SolidColorBrush x:Key="RedSoftBrush" Color="{StaticResource ColorRedSoft}" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <sys:Double x:Key="FontSizeCaption">12</sys:Double>
        <sys:Double x:Key="FontSizeBody">13</sys:Double>
        <sys:Double x:Key="FontSizeBodyLarge">14</sys:Double>
        <sys:Double x:Key="FontSizeTitle">18</sys:Double>
        <sys:Double x:Key="FontSizeDisplay">22</sys:Double>
        <sys:Double x:Key="ControlHeight">36</sys:Double>
        <sys:Double x:Key="SmallControlHeight">32</sys:Double>

        <CornerRadius x:Key="RadiusSmall">6</CornerRadius>
        <CornerRadius x:Key="RadiusMedium">8</CornerRadius>
        <CornerRadius x:Key="RadiusLarge">12</CornerRadius>
        <Thickness x:Key="PagePadding">18</Thickness>
        <Thickness x:Key="PanelPadding">16</Thickness>
        <Thickness x:Key="ControlPadding">12,0</Thickness>

        <DropShadowEffect x:Key="SoftShadow"
                          BlurRadius="20"
                          ShadowDepth="2"
                          Direction="270"
                          Color="#334155"
                          Opacity="0.06" />

        <Style x:Key="SectionTitleStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="{StaticResource FontSizeTitle}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style x:Key="SectionCaptionStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style x:Key="FieldValueTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style x:Key="PanelSurfaceStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushToken}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{StaticResource RadiusLarge}" />
            <Setter Property="Padding" Value="{StaticResource PanelPadding}" />
        </Style>

        <Style x:Key="StatusCardStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushToken}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{StaticResource RadiusLarge}" />
            <Setter Property="Padding" Value="12" />
        </Style>

        <Style x:Key="GroupBoxStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushToken}" />
            <Setter Property="BorderThickness" Value="0,1,0,0" />
            <Setter Property="Padding" Value="0,14,0,0" />
            <Setter Property="Margin" Value="0,0,0,18" />
        </Style>

        <Style x:Key="StatusPillStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{StaticResource SurfaceMutedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushToken}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{StaticResource RadiusSmall}" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Margin" Value="0,0,6,0" />
        </Style>

        <Style x:Key="ProgressStepStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushToken}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{StaticResource RadiusMedium}" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderStrongBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="{StaticResource ControlPadding}" />
            <Setter Property="MinHeight" Value="{StaticResource SmallControlHeight}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource RadiusMedium}"
                                MinHeight="{TemplateBinding MinHeight}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource SurfaceMutedBrush}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#AEB8C4" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="1" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.48" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="MinHeight" Value="{StaticResource ControlHeight}" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource RadiusMedium}"
                                MinHeight="{TemplateBinding MinHeight}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource AccentHoverBrush}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="1" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.48" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinHeight" Value="{StaticResource ControlHeight}" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#DC2626" />
            <Setter Property="BorderBrush" Value="#DC2626" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="MinHeight" Value="{StaticResource ControlHeight}" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource RadiusMedium}"
                                MinHeight="{TemplateBinding MinHeight}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#B91C1C" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#B91C1C" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="1" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#991B1B" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.48" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderStrongBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="MinHeight" Value="{StaticResource ControlHeight}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource RadiusMedium}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="Chrome" Property="Background" Value="#FEFFFF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.56" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type TabControl}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabControl}">
                        <DockPanel ClipToBounds="False">
                            <TabPanel IsItemsHost="True"
                                      DockPanel.Dock="Top"
                                      Background="Transparent"
                                      Margin="0,0,0,12"
                                      ClipToBounds="False" />
                            <ContentPresenter ContentSource="SelectedContent" />
                        </DockPanel>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type TabItem}">
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="MinWidth" Value="128" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Border x:Name="TabChrome"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource BorderStrongBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource RadiusMedium}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabChrome" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                <Setter TargetName="TabChrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabChrome" Property="Background" Value="{StaticResource SurfaceMutedBrush}" />
                                <Setter TargetName="TabChrome" Property="BorderBrush" Value="#AEB8C4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ListBox}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        </Style>

        <Style TargetType="{x:Type ListBoxItem}">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="ItemChrome"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="{StaticResource RadiusMedium}"
                                Padding="10">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="{StaticResource SurfaceMutedBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="#B8CAFA" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type CheckBox}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Grid Background="#F4F2EE">
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FDFDFC" BorderBrush="#E2DFD7" BorderThickness="0,0,0,1" Padding="14,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Width="32" Height="32" CornerRadius="6" Background="#EAF1FF" BorderBrush="#D7E2FF" BorderThickness="1" VerticalAlignment="Center">
                    <TextBlock Text="WSR" FontSize="9" FontWeight="Bold" Foreground="#2563EB" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <Border Grid.Column="1" Width="1" Height="20" Background="#E2DFD7" Margin="12,0" VerticalAlignment="Center" />
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Workflow Spec Recorder" FontSize="13" FontWeight="SemiBold" Foreground="#1C1B18" VerticalAlignment="Center" />
                    <TextBlock Text="v0.2.6 · 作者 Yumin" FontSize="10" Foreground="#9E9B93" Margin="12,1,0,0" VerticalAlignment="Center" />
                </StackPanel>
                <Border Grid.Column="4" Background="#EDEBE5" BorderBrush="#E2DFD7" BorderThickness="1" CornerRadius="8" Padding="10,4" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="7" Height="7" Fill="#16A34A" VerticalAlignment="Center" Margin="0,0,5,0" />
                        <TextBlock Text="本地服务" FontSize="11" Foreground="#78756E" Margin="0,0,10,0" VerticalAlignment="Center" />
                        <TextBlock Text="|" FontSize="10" Foreground="#9E9B93" Margin="0,0,10,0" VerticalAlignment="Center" />
                        <Ellipse Width="7" Height="7" Fill="{Binding ExtensionConnectionAccentBrush}" VerticalAlignment="Center" Margin="0,0,5,0" />
                        <TextBlock Text="{Binding ExtensionStatusLabel}" FontSize="11" Foreground="#78756E" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ExtensionInstallHint}" FontSize="11" Foreground="#78756E" VerticalAlignment="Center" Margin="4,0,10,0" />
                        <Button Content="新建流程" Command="{Binding NewSessionCommand}" Style="{StaticResource SecondaryButtonStyle}" MinHeight="24" Padding="8,0" Margin="0,0,4,0" />
                        <Button Content="打开扩展目录" Command="{Binding OpenExtensionFolderCommand}" Style="{StaticResource SecondaryButtonStyle}" MinHeight="24" Padding="8,0" Margin="0,0,4,0" />
                        <Button Content="检测" Command="{Binding CheckExtensionConnectionCommand}" Style="{StaticResource SecondaryButtonStyle}" MinHeight="24" Padding="8,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="224" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#FDFDFC" BorderBrush="#E2DFD7" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="1" Margin="8">
                        <TextBlock Text="工作区" FontSize="10" FontWeight="SemiBold" Foreground="#9E9B93" Margin="10,10,0,4" />
                        <Button Command="{Binding ShowRecordingWorkspaceCommand}" Background="#EEF4FF" BorderBrush="Transparent" Padding="12,9" HorizontalContentAlignment="Stretch" Margin="0,0,0,2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="●" Foreground="#2563EB" Margin="0,0,10,0" />
                                <TextBlock Grid.Column="1" Text="1 录制 / 编辑" Foreground="#2563EB" FontWeight="SemiBold" />
                                <Border Grid.Column="2" Background="#DCE8FF" CornerRadius="8" Padding="7,2">
                                    <TextBlock Text="{Binding StepCountBadge}" FontSize="10" Foreground="#2563EB" FontWeight="SemiBold" />
                                </Border>
                            </Grid>
                        </Button>
                        <Button Command="{Binding ShowGeneralizeWorkspaceCommand}" Background="Transparent" BorderBrush="Transparent" Padding="12,9" HorizontalContentAlignment="Stretch" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="◆" Foreground="#78756E" Margin="0,0,10,0" />
                                <TextBlock Grid.Column="1" Text="2 生成需求文档" Foreground="#78756E" FontWeight="SemiBold" />
                                <Border Grid.Column="2" Background="#EAF7EE" CornerRadius="8" Padding="7,2">
                                    <TextBlock Text="{Binding GeneralizeStatusBadge}" FontSize="10" Foreground="#16A34A" FontWeight="SemiBold" />
                                </Border>
                            </Grid>
                        </Button>
                    </StackPanel>

                    <Border Grid.Row="2" BorderBrush="#E2DFD7" BorderThickness="0,1,0,0" Padding="8">
                        <TextBlock Text="停止录制后会自动导出原始录制包并加入资料集。" TextWrapping="Wrap" Foreground="#78756E" FontSize="11" Margin="10,0" />
                    </Border>
                </Grid>
            </Border>

            <TabControl Grid.Column="1" SelectedIndex="{Binding SelectedWorkspaceIndex, Mode=TwoWay}" Background="Transparent" BorderThickness="0">
                <TabControl.Template>
                    <ControlTemplate TargetType="{x:Type TabControl}">
                        <ContentPresenter ContentSource="SelectedContent" />
                    </ControlTemplate>
                </TabControl.Template>

                <TabItem Header="录制 / 编辑">
                    <Grid Background="#F4F2EE">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="66" />
                            <RowDefinition Height="48" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="#FDFDFC" BorderBrush="#E2DFD7" BorderThickness="0,0,0,1" Padding="14,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.1*" />
                                    <ColumnDefinition Width="3.2*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="流程名称" FontSize="10" FontWeight="SemiBold" Foreground="#78756E" Margin="0,0,0,3" />
                                    <TextBox Text="{Binding ProjectName, UpdateSourceTrigger=PropertyChanged}" MinHeight="28" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                    <TextBlock Text="业务目标" FontSize="10" FontWeight="SemiBold" Foreground="#78756E" Margin="0,0,0,3" />
                                    <TextBox Text="{Binding Objective, UpdateSourceTrigger=PropertyChanged}" MinHeight="28" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                                    <Border Background="#F6F4F0" BorderBrush="#E2DFD7" BorderThickness="1" CornerRadius="12" Padding="10,6" Margin="0,0,6,0">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="7" Height="7" Fill="{Binding RecordingAccentBrush}" VerticalAlignment="Center" Margin="0,0,6,0" />
                                            <TextBlock Text="{Binding RecordingStatus}" FontWeight="SemiBold" FontSize="12" />
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#EEF4FF" BorderBrush="#DCE8FF" BorderThickness="1" CornerRadius="12" Padding="10,6">
                                        <TextBlock Text="{Binding StepCountLabel}" FontWeight="SemiBold" FontSize="12" Foreground="#2563EB" />
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="1" Background="#FDFDFC" BorderBrush="#E2DFD7" BorderThickness="0,0,0,1" Padding="14,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="● 开始录制" Command="{Binding StartRecordingCommand}" Style="{StaticResource DangerButtonStyle}" MinWidth="108" Margin="0,0,8,0" />
                                <TextBlock Grid.Column="1" Text="00:00" FontFamily="Consolas" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" Margin="4,0,14,0" />
                                <Border Grid.Column="2" Width="1" Background="#E2DFD7" Margin="0,0,14,0" />
                                <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Left">
                                    <Button Content="暂停" Command="{Binding PauseRecordingCommand}" Style="{StaticResource SecondaryButtonStyle}" MinWidth="56" Margin="0,0,6,0" />
                                    <Button Content="停止" Command="{Binding StopRecordingCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="筛选" Foreground="#78756E" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <Button Content="全部" Style="{StaticResource PrimaryButtonStyle}" MinHeight="26" Padding="12,0" Margin="0,0,4,0" />
                                    <Button Content="点击" Style="{StaticResource SecondaryButtonStyle}" MinHeight="26" Padding="10,0" Margin="0,0,4,0" />
                                    <Button Content="输入" Style="{StaticResource SecondaryButtonStyle}" MinHeight="26" Padding="10,0" Margin="0,0,4,0" />
                                    <Button Content="导航" Style="{StaticResource SecondaryButtonStyle}" MinHeight="26" Padding="10,0" Margin="0,0,4,0" />
                                    <Button Content="桌面" Style="{StaticResource SecondaryButtonStyle}" MinHeight="26" Padding="10,0" Margin="0,0,4,0" />
                                    <Button Content="下载" Style="{StaticResource SecondaryButtonStyle}" MinHeight="26" Padding="10,0" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="300" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="340" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="#FDFDFC" BorderBrush="#E2DFD7" BorderThickness="0,0,1,0">
                                <DockPanel>
                                    <Border DockPanel.Dock="Top" BorderBrush="#E2DFD7" BorderThickness="0,0,0,1" Padding="14,10">
                                        <TextBlock Text="步骤时间线" FontWeight="SemiBold" Foreground="#1C1B18" />
                                    </Border>
                                    <ListBox ItemsSource="{Binding Steps}" SelectedItem="{Binding SelectedStep}" BorderThickness="0" Background="#FDFDFC">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid MinHeight="58">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="28" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Ellipse Width="8" Height="8" Fill="#2563EB" VerticalAlignment="Top" Margin="10,12,0,0" />
                                                    <StackPanel Grid.Column="1" Margin="0,8,8,8">
                                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="#1C1B18" TextWrapping="Wrap" />
                                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                            <Border Background="#EAF1FF" CornerRadius="3" Padding="5,1" Margin="0,0,6,0">
                                                                <TextBlock Text="浏览器" FontSize="10" Foreground="#2563EB" FontWeight="SemiBold" />
                                                            </Border>
                                                            <TextBlock Text="{Binding Action}" FontSize="11" Foreground="#78756E" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </DockPanel>
                            </Border>

                            <Border Grid.Column="1" Background="#F6F4F0" BorderBrush="#E2DFD7" BorderThickness="0,0,1,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="38" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="#FDFDFC" BorderBrush="#E2DFD7" BorderThickness="0,0,0,1" Padding="14,0">
                                        <TextBlock Text="步骤预览" FontSize="12" FontWeight="SemiBold" Foreground="#4A4842" VerticalAlignment="Center" />
                                    </Border>
                                    <Grid Grid.Row="1">
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="360">
                                            <TextBlock Text="选择一个步骤查看预览" FontWeight="SemiBold" Foreground="#1C1B18" HorizontalAlignment="Center" />
                                            <TextBlock Text="左侧时间线中选择步骤后，此处将显示步骤概览和截图预览" TextWrapping="Wrap" TextAlignment="Center" Foreground="#78756E" Margin="0,10,0,0" />
                                        </StackPanel>
                                        <Image Source="{Binding SelectedStep.ScreenshotPath}" Stretch="Uniform" Margin="18" />
                                    </Grid>
                                </Grid>
                            </Border>

                            <Border Grid.Column="2" Background="#FDFDFC">
                                <DockPanel>
                                    <Border DockPanel.Dock="Top" BorderBrush="#E2DFD7" BorderThickness="0,0,0,1" Padding="14,10">
                                        <Grid>
                                            <TextBlock Text="步骤属性" FontWeight="SemiBold" Foreground="#1C1B18" />
                                            <TextBlock Text="×" HorizontalAlignment="Right" Foreground="#78756E" />
                                        </Grid>
                                    </Border>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel Margin="14">
                                            <TextBlock Text="基本信息" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBlock Text="优先补充业务标题、变量名和成功判定；选择器与截图路径主要用于排查和辅助理解。" Style="{StaticResource SectionCaptionStyle}" Margin="0,0,0,14" />
                                            <TextBlock Text="业务标题" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBox Text="{Binding SelectedStep.Title, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />
                                            <TextBlock Text="动作类型" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBlock Text="{Binding SelectedStep.Action}" Style="{StaticResource FieldValueTextStyle}" />
                                            <TextBlock Text="页面标题" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBlock Text="{Binding SelectedStep.PageTitle}" Style="{StaticResource FieldValueTextStyle}" />
                                            <TextBlock Text="页面地址" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBlock Text="{Binding SelectedStep.PageUrl}" Style="{StaticResource FieldValueTextStyle}" />
                                            <Border BorderBrush="#E2DFD7" BorderThickness="0,1,0,0" Margin="0,10,0,14" />
                                            <TextBlock Text="目标元素" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBlock Text="{Binding SelectedStep.Element.DisplayName}" Style="{StaticResource FieldValueTextStyle}" />
                                            <TextBlock Text="选择器" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBlock Text="{Binding SelectedStep.Element.CssSelector}" Style="{StaticResource FieldValueTextStyle}" />
                                            <Border BorderBrush="#E2DFD7" BorderThickness="0,1,0,0" Margin="0,10,0,14" />
                                            <TextBlock Text="数据绑定" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBlock Text="变量名" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBox Text="{Binding SelectedStep.VariableName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />
                                            <TextBlock Text="固定值" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBox Text="{Binding SelectedStep.LiteralValue, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />
                                            <CheckBox Content="敏感字段" IsChecked="{Binding SelectedStep.IsSensitive}" Margin="0,0,0,12" />
                                            <TextBlock Text="成功判定" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBox Text="{Binding SelectedStep.SuccessCriteria, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" AcceptsReturn="True" Height="76" VerticalContentAlignment="Top" Margin="0,0,0,12" />
                                            <TextBlock Text="备注" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBox Text="{Binding SelectedStep.Notes, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" AcceptsReturn="True" Height="96" VerticalContentAlignment="Top" />
                                        </StackPanel>
                                    </ScrollViewer>
                                </DockPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="生成需求文档">
                    <Grid Background="#F4F2EE">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="380" />
                        </Grid.ColumnDefinitions>
                        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="18">
                                <TextBlock Text="2 生成需求文档" FontSize="20" FontWeight="SemiBold" Foreground="#1C1B18" Margin="0,0,0,8" />
                                <TextBlock Text="资料是主输入，录制步骤是代表性示例。导出原始录制包后会自动加入资料集。" Foreground="#78756E" TextWrapping="Wrap" Margin="0,0,0,14" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <Button Content="生成需求文档" Command="{Binding GenerateGeneralizedRequirementCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0" />
                                    <Button Content="打开最终文档目录" Command="{Binding OpenGeneralizedFolderCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                                </StackPanel>
                                <Border Background="#EAF1FF" BorderBrush="#2563EB" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,14" Visibility="{Binding IsGeneratingFinalRequirement, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding GenerationStageTitle}" FontSize="16" FontWeight="SemiBold" Foreground="#1D4ED8" Margin="0,0,0,4" />
                                        <TextBlock Text="{Binding GenerationStageDetail}" TextWrapping="Wrap" Foreground="#1F3F8F" />
                                    </StackPanel>
                                </Border>
                                <Border Background="#EAF7EE" BorderBrush="#16A34A" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,14" Visibility="{Binding IsFinalRequirementResultVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding GenerationStageTitle}" FontSize="16" FontWeight="SemiBold" Foreground="#166534" Margin="0,0,0,4" />
                                        <TextBlock Text="{Binding GenerationStageDetail}" TextWrapping="Wrap" Foreground="#166534" Margin="0,0,0,10" />
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="打开最终文档" Command="{Binding OpenFinalRequirementDocumentCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0" />
                                            <Button Content="打开目录" Command="{Binding OpenGeneralizedFolderCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="资料集" FontWeight="SemiBold" Foreground="#1C1B18" Margin="0,0,0,8" />
                                <TextBlock Text="{Binding SourceMaterialSummary}" TextWrapping="Wrap" Foreground="#4A4842" Margin="0,0,0,8" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button Content="添加资料" Command="{Binding BrowseSourceMaterialsCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0" />
                                    <Button Content="清空资料" Command="{Binding ClearSourceMaterialsCommand}" Style="{StaticResource GhostButtonStyle}" />
                                </StackPanel>
                                <TextBox Text="{Binding SourceMaterialPaths, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Height="96" VerticalContentAlignment="Top" Margin="0,0,0,8" />
                                <TextBlock Text="{Binding SourceMaterialDetailHint}" TextWrapping="Wrap" Foreground="#78756E" Margin="0,0,0,18" />
                                <TextBlock Text="模型配置" FontWeight="SemiBold" Foreground="#1C1B18" Margin="0,0,0,10" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Button Content="MiniMax 国内预设" Command="{Binding UseMiniMaxPresetCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0" />
                                    <Button Content="DeepSeek 预设" Command="{Binding UseDeepSeekPresetCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                                </StackPanel>
                                <TextBlock Text="服务商" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Text="{Binding ProviderName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" />
                                <TextBlock Text="Base URL" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Text="{Binding LlmBaseUrl, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" />
                                <TextBlock Text="模型名" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Text="{Binding LlmModel, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" />
                                <TextBlock Text="API Key（明文保存到当前 Windows 用户配置文件）" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Text="{Binding LlmApiKey, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6" />
                                <TextBlock Text="{Binding ModelConfigurationHint}" TextWrapping="Wrap" Foreground="#78756E" Margin="0,0,0,12" />
                                <TextBlock Text="补充要求" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Text="{Binding ExtraInstruction, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" AcceptsReturn="True" Height="88" VerticalContentAlignment="Top" />
                            </StackPanel>
                        </ScrollViewer>
                        <Border Grid.Column="1" Background="#FDFDFC" BorderBrush="#E2DFD7" BorderThickness="1,0,0,0">
                            <StackPanel Margin="14">
                                <TextBlock Text="生成状态" FontWeight="SemiBold" Foreground="#1C1B18" Margin="0,0,0,10" />
                                <Border Background="#F6F4F0" BorderBrush="#E2DFD7" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,14">
                                    <TextBlock Text="{Binding GeneralizedStatus}" TextWrapping="Wrap" Foreground="#4A4842" />
                                </Border>
                                <TextBlock Text="{Binding RawExportChecklistText}" TextWrapping="Wrap" Foreground="#78756E" Margin="0,0,0,6" />
                                <TextBlock Text="{Binding FinalRequirementChecklistText}" TextWrapping="Wrap" Foreground="#78756E" Margin="0,0,0,18" />
                                <TextBlock Text="导出文件" FontWeight="SemiBold" Foreground="#1C1B18" Margin="0,0,0,8" />
                                <TextBlock Text="APA-generalized-requirements.md&#x0a;workflow-spec.json&#x0a;llm-prompt.txt&#x0a;generation-mode.txt" Foreground="#1C1B18" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>

