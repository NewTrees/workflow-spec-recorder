<Window x:Class="ApaFlowRecorder.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="Workflow Spec Recorder"
        Icon="Assets/AppIcon.ico"
        Height="880"
        Width="1440"
        MinHeight="780"
        MinWidth="1180"
        FontFamily="Segoe UI, Microsoft YaHei UI, Microsoft YaHei, sans-serif"
        FontSize="13"
        Foreground="#1F2328"
        Background="#F6F7F9">
    <Window.Resources>
        <FontFamily x:Key="AppFontFamily">Segoe UI, Microsoft YaHei UI, Microsoft YaHei, sans-serif</FontFamily>

        <Color x:Key="ColorBackground">#F6F7F9</Color>
        <Color x:Key="ColorSurface">#FFFFFF</Color>
        <Color x:Key="ColorSurfaceMuted">#FAFAFB</Color>
        <Color x:Key="ColorTextPrimary">#1F2328</Color>
        <Color x:Key="ColorTextSecondary">#5D6673</Color>
        <Color x:Key="ColorTextTertiary">#8A94A3</Color>
        <Color x:Key="ColorBorder">#E1E5EA</Color>
        <Color x:Key="ColorBorderStrong">#CBD2DA</Color>
        <Color x:Key="ColorAccent">#2563EB</Color>
        <Color x:Key="ColorAccentHover">#1D4ED8</Color>
        <Color x:Key="ColorAccentSoft">#EAF1FF</Color>
        <Color x:Key="ColorNeutral">#6B7280</Color>
        <Color x:Key="ColorNeutralSoft">#F1F3F5</Color>
        <Color x:Key="ColorGreen">#16833A</Color>
        <Color x:Key="ColorGreenSoft">#EAF7EE</Color>
        <Color x:Key="ColorAmber">#B7791F</Color>
        <Color x:Key="ColorAmberSoft">#FFF6DE</Color>
        <Color x:Key="ColorRed">#C92A2A</Color>
        <Color x:Key="ColorRedSoft">#FFF0F0</Color>

        <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource ColorBackground}" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource ColorSurface}" />
        <SolidColorBrush x:Key="SurfaceMutedBrush" Color="{StaticResource ColorSurfaceMuted}" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource ColorTextPrimary}" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource ColorTextSecondary}" />
        <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource ColorTextTertiary}" />
        <SolidColorBrush x:Key="BorderBrushToken" Color="{StaticResource ColorBorder}" />
        <SolidColorBrush x:Key="BorderStrongBrush" Color="{StaticResource ColorBorderStrong}" />
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource ColorAccent}" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource ColorAccentHover}" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="{StaticResource ColorAccentSoft}" />
        <SolidColorBrush x:Key="NeutralBrush" Color="{StaticResource ColorNeutral}" />
        <SolidColorBrush x:Key="NeutralSoftBrush" Color="{StaticResource ColorNeutralSoft}" />
        <SolidColorBrush x:Key="GreenBrush" Color="{StaticResource ColorGreen}" />
        <SolidColorBrush x:Key="GreenSoftBrush" Color="{StaticResource ColorGreenSoft}" />
        <SolidColorBrush x:Key="AmberBrush" Color="{StaticResource ColorAmber}" />
        <SolidColorBrush x:Key="AmberSoftBrush" Color="{StaticResource ColorAmberSoft}" />
        <SolidColorBrush x:Key="RedBrush" Color="{StaticResource ColorRed}" />
        <SolidColorBrush x:Key="RedSoftBrush" Color="{StaticResource ColorRedSoft}" />

        <sys:Double x:Key="FontSizeCaption">12</sys:Double>
        <sys:Double x:Key="FontSizeBody">13</sys:Double>
        <sys:Double x:Key="FontSizeBodyLarge">14</sys:Double>
        <sys:Double x:Key="FontSizeTitle">18</sys:Double>
        <sys:Double x:Key="FontSizeDisplay">22</sys:Double>
        <sys:Double x:Key="ControlHeight">36</sys:Double>
        <sys:Double x:Key="SmallControlHeight">32</sys:Double>

        <CornerRadius x:Key="RadiusSmall">6</CornerRadius>
        <CornerRadius x:Key="RadiusMedium">8</CornerRadius>
        <CornerRadius x:Key="RadiusLarge">12</CornerRadius>
        <Thickness x:Key="PagePadding">18</Thickness>
        <Thickness x:Key="PanelPadding">16</Thickness>
        <Thickness x:Key="ControlPadding">12,0</Thickness>

        <DropShadowEffect x:Key="SoftShadow"
                          BlurRadius="20"
                          ShadowDepth="2"
                          Direction="270"
                          Color="#334155"
                          Opacity="0.06" />

        <Style x:Key="SectionTitleStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="{StaticResource FontSizeTitle}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style x:Key="SectionCaptionStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style x:Key="FieldValueTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style x:Key="PanelSurfaceStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushToken}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{StaticResource RadiusLarge}" />
            <Setter Property="Padding" Value="{StaticResource PanelPadding}" />
        </Style>

        <Style x:Key="StatusCardStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushToken}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="{StaticResource RadiusLarge}" />
            <Setter Property="Padding" Value="18" />
        </Style>

        <Style x:Key="GroupBoxStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushToken}" />
            <Setter Property="BorderThickness" Value="0,1,0,0" />
            <Setter Property="Padding" Value="0,14,0,0" />
            <Setter Property="Margin" Value="0,0,0,18" />
        </Style>

        <Style TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderStrongBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="{StaticResource ControlPadding}" />
            <Setter Property="MinHeight" Value="{StaticResource SmallControlHeight}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource RadiusMedium}"
                                MinHeight="{TemplateBinding MinHeight}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource SurfaceMutedBrush}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#AEB8C4" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="RenderTransform">
                                    <Setter.Value>
                                        <TranslateTransform Y="1" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.48" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="MinHeight" Value="{StaticResource ControlHeight}" />
            <Setter Property="Padding" Value="16,0" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinHeight" Value="{StaticResource ControlHeight}" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        </Style>

        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderStrongBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="MinHeight" Value="{StaticResource ControlHeight}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource RadiusMedium}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="Chrome" Property="Background" Value="#FEFFFF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.56" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type TabControl}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style TargetType="{x:Type TabItem}">
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Border x:Name="TabChrome"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="{StaticResource RadiusMedium}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabChrome" Property="Background" Value="{StaticResource SurfaceBrush}" />
                                <Setter TargetName="TabChrome" Property="BorderBrush" Value="{StaticResource BorderBrushToken}" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabChrome" Property="Background" Value="{StaticResource SurfaceMutedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ListBox}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        </Style>

        <Style TargetType="{x:Type ListBoxItem}">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="ItemChrome"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="{StaticResource RadiusMedium}"
                                Padding="10">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="{StaticResource SurfaceMutedBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                <Setter TargetName="ItemChrome" Property="BorderBrush" Value="#B8CAFA" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type CheckBox}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Grid Margin="{StaticResource PagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrushToken}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusLarge}"
                Padding="14"
                Margin="0,0,0,12"
                Effect="{StaticResource SoftShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="42"
                            Height="42"
                            CornerRadius="{StaticResource RadiusMedium}"
                            Background="{StaticResource AccentSoftBrush}"
                            BorderBrush="#CFDAFF"
                            BorderThickness="1"
                            Margin="0,0,12,0">
                        <Image Source="Assets/AppIcon.ico" Width="32" Height="32" Stretch="Uniform" />
                    </Border>
                    <StackPanel>
                        <TextBlock Text="{Binding ProductName}"
                                   FontSize="{StaticResource FontSizeTitle}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="{Binding ProductInfoSummary}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="{StaticResource SurfaceMutedBrush}"
                        BorderBrush="{StaticResource BorderBrushToken}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusMedium}"
                        Padding="14,8"
                        Margin="26,0"
                        VerticalAlignment="Center">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding ProjectName}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding StatusMessage}"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                        <Border Grid.Column="1"
                                x:Name="ToolbarStatusPill"
                                CornerRadius="{StaticResource RadiusSmall}"
                                Padding="8,3"
                                Margin="14,0,0,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding RecordingStatus}"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource NeutralBrush}" />
                            <Border.Style>
                                <Style TargetType="{x:Type Border}">
                                    <Setter Property="Background" Value="{StaticResource NeutralSoftBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RecordingStatus}" Value="录制中">
                                            <Setter Property="Background" Value="{StaticResource GreenSoftBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding RecordingStatus}" Value="已暂停">
                                            <Setter Property="Background" Value="{StaticResource AmberSoftBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                    </Grid>
                </Border>

                <WrapPanel Grid.Column="2" VerticalAlignment="Center" ItemHeight="36">
                    <Button Content="新建流程" Command="{Binding NewSessionCommand}" Style="{StaticResource GhostButtonStyle}" Margin="0,0,6,0" />
                    <Button Content="开始/继续录制" Command="{Binding StartRecordingCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,6,0" />
                    <Button Content="暂停" Command="{Binding PauseRecordingCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,6,0" />
                    <Button Content="停止" Command="{Binding StopRecordingCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,6,0" />
                    <Button Content="检测插件" Command="{Binding CheckExtensionConnectionCommand}" Style="{StaticResource GhostButtonStyle}" Margin="0,0,6,0" />
                    <Button Content="导出录制包" Command="{Binding ExportCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                </WrapPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1">
            <TabItem Header="录制 / 编辑">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource PanelSurfaceStyle}" Margin="0,0,0,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="流程基础信息" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,12" />
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.2*" />
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="2*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="流程名称" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBox Text="{Binding ProjectName, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                    <TextBlock Text="业务目标" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBox Text="{Binding Objective, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="前置条件" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBox Text="{Binding Preconditions, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Margin="0,0,12,0">
                            <Border.Style>
                                <Style TargetType="{x:Type Border}" BasedOn="{StaticResource StatusCardStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RecordingStatus}" Value="录制中">
                                            <Setter Property="Background" Value="{StaticResource GreenSoftBrush}" />
                                            <Setter Property="BorderBrush" Value="#BFDEC8" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding RecordingStatus}" Value="已暂停">
                                            <Setter Property="Background" Value="{StaticResource AmberSoftBrush}" />
                                            <Setter Property="BorderBrush" Value="#EBD492" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="10" Height="10" CornerRadius="5" Margin="0,5,12,0">
                                    <Border.Style>
                                        <Style TargetType="{x:Type Border}">
                                            <Setter Property="Background" Value="{StaticResource NeutralBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RecordingStatus}" Value="录制中">
                                                    <Setter Property="Background" Value="{StaticResource GreenBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding RecordingStatus}" Value="已暂停">
                                                    <Setter Property="Background" Value="{StaticResource AmberBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding RecordingIndicatorText}"
                                               FontSize="{StaticResource FontSizeDisplay}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Text="{Binding RecordingStateText}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,4,0,10" />
                                    <TextBlock Text="{Binding LiveCaptureSummary}"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding LastCaptureSummary}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,6,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource StatusCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Width="10" Height="10" CornerRadius="5" Background="{StaticResource AmberBrush}" Margin="0,5,12,0" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="插件连接与导出状态"
                                               FontSize="{StaticResource FontSizeDisplay}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Text="{Binding ExtensionConnectionStatus}"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,10" />
                                    <TextBlock Text="{Binding ExportHint}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <Button Grid.Column="2"
                                        Content="打开插件目录"
                                        Command="{Binding OpenExtensionFolderCommand}"
                                        Style="{StaticResource GhostButtonStyle}"
                                        VerticalAlignment="Top"
                                        Margin="12,0,0,0" />
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="320" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="380" MinWidth="360" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource PanelSurfaceStyle}" Padding="14" Margin="0,0,12,0">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                                    <TextBlock Text="步骤时间线" Style="{StaticResource SectionTitleStyle}" />
                                    <TextBlock Text="{Binding LiveCaptureSummary}" Style="{StaticResource SectionCaptionStyle}" Margin="0,4,0,0" />
                                </StackPanel>
                                <ListBox ItemsSource="{Binding Steps}" SelectedItem="{Binding SelectedStep}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="18" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid>
                                                    <Rectangle Width="1" Fill="{StaticResource BorderBrushToken}" HorizontalAlignment="Center" Margin="0,8,0,-18" />
                                                    <Ellipse Width="8" Height="8" Fill="{StaticResource AccentBrush}" VerticalAlignment="Top" Margin="0,6,0,0" />
                                                </Grid>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Title}"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding Action}"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               FontSize="{StaticResource FontSizeCaption}"
                                                               Margin="0,4,0,0" />
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource PanelSurfaceStyle}" Padding="14" Margin="0,0,12,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="步骤预览" Style="{StaticResource SectionTitleStyle}" />
                                        <TextBlock Text="{Binding SelectedStep.Title}"
                                                   FontSize="{StaticResource FontSizeDisplay}"
                                                   FontWeight="SemiBold"
                                                   Margin="0,8,0,4"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding SelectedStep.SuccessCriteria}"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <Border Grid.Column="1"
                                            Background="{StaticResource NeutralSoftBrush}"
                                            CornerRadius="{StaticResource RadiusSmall}"
                                            Padding="8,4"
                                            VerticalAlignment="Top"
                                            Margin="14,0,0,0">
                                        <TextBlock Text="{Binding SelectedStep.Action}"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="{StaticResource FontSizeCaption}"
                                                   FontWeight="SemiBold" />
                                    </Border>
                                </Grid>
                                <Border Grid.Row="1"
                                        Margin="0,16,0,0"
                                        Background="{StaticResource SurfaceMutedBrush}"
                                        BorderBrush="{StaticResource BorderBrushToken}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource RadiusLarge}">
                                    <Grid>
                                        <TextBlock Text="当前步骤没有截图或尚未选择步骤"
                                                   Foreground="{StaticResource TextTertiaryBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                        <Image Source="{Binding SelectedStep.ScreenshotPath}" Stretch="Uniform" Margin="12" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource PanelSurfaceStyle}" Padding="14">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="步骤属性" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,12" />

                                    <Border Style="{StaticResource GroupBoxStyle}">
                                        <StackPanel>
                                            <TextBlock Text="基本信息" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBlock Text="业务标题" Style="{StaticResource FieldLabelStyle}" Margin="0,8,0,6" />
                                            <TextBox Text="{Binding SelectedStep.Title, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />
                                            <TextBlock Text="动作类型" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBlock Text="{Binding SelectedStep.Action}" Style="{StaticResource FieldValueTextStyle}" />
                                            <TextBlock Text="页面标题" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBlock Text="{Binding SelectedStep.PageTitle}" Style="{StaticResource FieldValueTextStyle}" />
                                            <TextBlock Text="页面地址" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBlock Text="{Binding SelectedStep.PageUrl}" Style="{StaticResource FieldValueTextStyle}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource GroupBoxStyle}">
                                        <StackPanel>
                                            <TextBlock Text="目标元素" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBlock Text="元素名称" Style="{StaticResource FieldLabelStyle}" Margin="0,8,0,6" />
                                            <TextBlock Text="{Binding SelectedStep.Element.DisplayName}" Style="{StaticResource FieldValueTextStyle}" />
                                            <TextBlock Text="选择器" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBlock Text="{Binding SelectedStep.Element.CssSelector}" Style="{StaticResource FieldValueTextStyle}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource GroupBoxStyle}">
                                        <StackPanel>
                                            <TextBlock Text="数据绑定" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBlock Text="变量名" Style="{StaticResource FieldLabelStyle}" Margin="0,8,0,6" />
                                            <TextBox Text="{Binding SelectedStep.VariableName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />
                                            <TextBlock Text="固定值" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBox Text="{Binding SelectedStep.LiteralValue, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />
                                            <CheckBox Content="敏感字段" IsChecked="{Binding SelectedStep.IsSensitive}" Margin="0,0,0,4" />
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource GroupBoxStyle}" Margin="0">
                                        <StackPanel>
                                            <TextBlock Text="截图与备注" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBlock Text="截图路径" Style="{StaticResource FieldLabelStyle}" Margin="0,8,0,6" />
                                            <TextBlock Text="{Binding SelectedStep.ScreenshotPath}" Style="{StaticResource FieldValueTextStyle}" />
                                            <TextBlock Text="成功判定" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBox Text="{Binding SelectedStep.SuccessCriteria, UpdateSourceTrigger=PropertyChanged}"
                                                     Margin="0,0,0,12"
                                                     TextWrapping="Wrap"
                                                     AcceptsReturn="True"
                                                     Height="76"
                                                     VerticalContentAlignment="Top" />
                                            <TextBlock Text="备注" Style="{StaticResource FieldLabelStyle}" />
                                            <TextBox Text="{Binding SelectedStep.Notes, UpdateSourceTrigger=PropertyChanged}"
                                                     TextWrapping="Wrap"
                                                     AcceptsReturn="True"
                                                     Height="96"
                                                     VerticalContentAlignment="Top" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="泛化需求">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="470" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource PanelSurfaceStyle}" Padding="16" Margin="0,0,12,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="需求资料与模型设置" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,6" />
                                <TextBlock Text="{Binding SourceMaterialSummary}" TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button Content="添加资料" Command="{Binding BrowseSourceMaterialsCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0" />
                                    <Button Content="清空资料" Command="{Binding ClearSourceMaterialsCommand}" Style="{StaticResource GhostButtonStyle}" />
                                </StackPanel>
                                <TextBox Text="{Binding SourceMaterialPaths, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Height="120"
                                         VerticalContentAlignment="Top"
                                         Margin="0,0,0,18" />

                                <Border Background="{StaticResource SurfaceMutedBrush}"
                                        BorderBrush="{StaticResource BorderBrushToken}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource RadiusMedium}"
                                        Padding="12"
                                        Margin="0,0,0,18">
                                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" Text="资料是主输入；录制/编辑页的步骤是代表性示例。导出原始录制包后会自动加入资料集，生成时会结合步骤文字、截图视觉信息和资料内容理解业务意图。" />
                                </Border>

                                <TextBlock Text="大模型设置" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,12" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Button Content="MiniMax 国内预设" Command="{Binding UseMiniMaxPresetCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0" />
                                    <Button Content="DeepSeek 预设" Command="{Binding UseDeepSeekPresetCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                                </StackPanel>
                                <TextBlock Text="服务商" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Text="{Binding ProviderName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" />
                                <TextBlock Text="Base URL" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Text="{Binding LlmBaseUrl, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" />
                                <TextBlock Text="模型名" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Text="{Binding LlmModel, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" />
                                <TextBlock Text="API Key（明文保存到当前 Windows 用户配置文件）" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Text="{Binding LlmApiKey, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6" />
                                <TextBlock Text="{Binding LlmSettingsConfigPath}" TextWrapping="Wrap" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,18" />
                                <TextBlock Text="补充要求" Style="{StaticResource FieldLabelStyle}" />
                                <TextBox Text="{Binding ExtraInstruction, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" AcceptsReturn="True" Height="110" VerticalContentAlignment="Top" Margin="0,0,0,18" />
                                <TextBlock Text="提示词模板" Style="{StaticResource FieldLabelStyle}" />
                                <TextBlock Text="{Binding PromptTemplateConfigPath}" TextWrapping="Wrap" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,8" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button Content="保存模板" Command="{Binding SavePromptTemplateCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0" />
                                    <Button Content="恢复默认" Command="{Binding ResetPromptTemplateCommand}" Style="{StaticResource GhostButtonStyle}" Margin="0,0,8,0" />
                                    <Button Content="打开模板文件" Command="{Binding OpenPromptTemplateFileCommand}" Style="{StaticResource GhostButtonStyle}" />
                                </StackPanel>
                                <TextBox Text="{Binding PromptTemplate, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         Height="220"
                                         VerticalContentAlignment="Top"
                                         Margin="0,0,0,18" />
                                <Button Content="生成 APA 需求文档" Command="{Binding GenerateGeneralizedRequirementCommand}" Style="{StaticResource PrimaryButtonStyle}" />
                                <Button Content="打开泛化导出目录" Command="{Binding OpenGeneralizedFolderCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,10,0,0" />
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource PanelSurfaceStyle}" Padding="18">
                        <StackPanel>
                            <TextBlock Text="生成说明" Style="{StaticResource SectionTitleStyle}" Margin="0,0,0,12" />
                            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" Text="泛化需求页会综合多份资料和可选录制示例：可读取的文本和 Office 文件用于识别业务规则、输入结构和输出结构；录制截图会作为视觉证据发给支持图像输入的大模型；PDF 与未知类型附件会作为参考文件加入并记录文件信息。没有录制步骤时，会生成纯资料处理型 APA 需求。" />
                            <Border Background="{StaticResource SurfaceMutedBrush}"
                                    BorderBrush="{StaticResource BorderBrushToken}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource RadiusMedium}"
                                    Padding="12"
                                    Margin="0,18,0,0">
                                <TextBlock Text="{Binding GeneralizedStatus}" TextWrapping="Wrap" Foreground="{StaticResource TextPrimaryBrush}" />
                            </Border>
                            <TextBlock Text="导出文件" Style="{StaticResource SectionTitleStyle}" Margin="0,24,0,8" />
                            <Border Background="{StaticResource SurfaceMutedBrush}"
                                    BorderBrush="{StaticResource BorderBrushToken}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource RadiusMedium}"
                                    Padding="12">
                                <StackPanel>
                                    <TextBlock Text="APA-generalized-requirements.md" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6" />
                                    <TextBlock Text="workflow-spec.json" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6" />
                                    <TextBlock Text="llm-prompt.txt" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6" />
                                    <TextBlock Text="generation-mode.txt" Foreground="{StaticResource TextPrimaryBrush}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrushToken}"
                BorderThickness="1"
                CornerRadius="{StaticResource RadiusMedium}"
                Padding="12"
                Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding RecordingStatus}" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" />
                <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" Foreground="{StaticResource TextSecondaryBrush}" Margin="18,0,0,0" TextTrimming="CharacterEllipsis" />
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBlock Text="{Binding ProductInfoSummary}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,18,0" />
                    <TextBlock Text="{Binding ServerStatus}" Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
