<Window x:Class="ApaFlowRecorder.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ApaFlowRecorder.Desktop"
        mc:Ignorable="d"
        Title="APA 流程录制器"
        Height="760"
        Width="1320"
        MinHeight="680"
        MinWidth="1100"
        Background="#F5F7FB">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="16" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="APA 流程录制器" FontSize="24" FontWeight="Bold" Foreground="#172033" />
                    <TextBlock Text="浏览器优先 MVP：把真实操作沉淀成 APA 可消费的流程规格" Margin="0,5,0,0" Foreground="#64748B" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="新建" Command="{Binding NewSessionCommand}" Margin="0,0,8,0" Padding="16,8" />
                    <Button Content="开始录制" Command="{Binding StartRecordingCommand}" Margin="0,0,8,0" Padding="16,8" />
                    <Button Content="暂停" Command="{Binding PauseRecordingCommand}" Margin="0,0,8,0" Padding="16,8" />
                    <Button Content="结束" Command="{Binding StopRecordingCommand}" Margin="0,0,8,0" Padding="16,8" />
                    <Button Content="导出" Command="{Binding ExportCommand}" Margin="0,0,8,0" Padding="16,8" />
                    <Button Content="打开导出目录" Command="{Binding OpenExportFolderCommand}" Padding="16,8" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="16" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="3*" />
                </Grid.ColumnDefinitions>

                <StackPanel Margin="0,0,12,0">
                    <TextBlock Text="流程名称" FontWeight="SemiBold" />
                    <TextBox Text="{Binding ProjectName, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock Text="项目目标" FontWeight="SemiBold" />
                    <TextBox Text="{Binding Objective, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="前置条件" FontWeight="SemiBold" />
                    <TextBox Text="{Binding Preconditions, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="380" />
            </Grid.ColumnDefinitions>

            <Border Background="White" CornerRadius="12" Padding="14" Margin="0,0,14,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="步骤时间线" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10" />
                    <ListBox ItemsSource="{Binding Steps}" SelectedItem="{Binding SelectedStep}" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="0,10">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding Action}" Foreground="#64748B" Margin="0,4,0,0" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="14" Margin="0,0,14,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="步骤预览" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding SelectedStep.Title}" FontSize="22" FontWeight="Bold" Margin="0,12,0,4" />
                        <TextBlock Text="{Binding SelectedStep.SuccessCriteria}" Foreground="#64748B" TextWrapping="Wrap" />
                    </StackPanel>

                    <Border Grid.Row="1" Margin="0,16,0,0" Background="#F8FAFC" CornerRadius="10">
                        <Grid>
                            <TextBlock Text="当前步骤暂无截图" Foreground="#94A3B8" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <Image Source="{Binding SelectedStep.ScreenshotPath}" Stretch="Uniform" Margin="12" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="步骤编辑" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                        <TextBlock Text="业务标题" FontWeight="SemiBold" />
                        <TextBox Text="{Binding SelectedStep.Title, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,12" />
                        <TextBlock Text="目标元素" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding SelectedStep.Element.DisplayName}" Margin="0,6,0,12" Foreground="#475569" TextWrapping="Wrap" />
                        <TextBlock Text="推荐定位方式" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding SelectedStep.Element.CssSelector}" Margin="0,6,0,12" Foreground="#475569" TextWrapping="Wrap" />
                        <TextBlock Text="变量名（留空表示使用固定值）" FontWeight="SemiBold" />
                        <TextBox Text="{Binding SelectedStep.VariableName, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,12" />
                        <TextBlock Text="固定值" FontWeight="SemiBold" />
                        <TextBox Text="{Binding SelectedStep.LiteralValue, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,12" />
                        <CheckBox Content="敏感字段" IsChecked="{Binding SelectedStep.IsSensitive}" Margin="0,0,0,12" />
                        <TextBlock Text="成功判定" FontWeight="SemiBold" />
                        <TextBox Text="{Binding SelectedStep.SuccessCriteria, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,12" TextWrapping="Wrap" AcceptsReturn="True" Height="72" />
                        <TextBlock Text="备注" FontWeight="SemiBold" />
                        <TextBox Text="{Binding SelectedStep.Notes, UpdateSourceTrigger=PropertyChanged}" Margin="0,6,0,0" TextWrapping="Wrap" AcceptsReturn="True" Height="96" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="3" Background="#172033" CornerRadius="12" Padding="14" Margin="0,14,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding RecordingStatus}" Foreground="White" FontWeight="Bold" />
                <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" Foreground="#CBD5E1" Margin="18,0,0,0" />
                <TextBlock Grid.Column="2" Text="{Binding ServerStatus}" Foreground="#CBD5E1" />
            </Grid>
        </Border>
    </Grid>
</Window>
